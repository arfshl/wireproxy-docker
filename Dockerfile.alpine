# STEP 1 BUILD
FROM --platform=${BUILDPLATFORM} golang:alpine AS builder
ARG TARGETARCH
ARG TARGETVARIANT
WORKDIR /app

RUN apk add --no-cache \
    build-base \
    git \
    make \
    cmake

RUN cd /app && git clone https://github.com/windtf/wireproxy

RUN cd /app/wireproxy && GOOS=linux GOARCH=${TARGETARCH} make

# Smoke test
RUN cd /app/wireproxy && ./wireproxy -h

# STEP 2 RUNTIME
FROM --platform=${BUILDPLATFORM} debian:trixie-slim 
WORKDIR /app
COPY --from=builder /usr/src/wireproxy/wireproxy /usr/bin/wireproxy
EXPOSE 25565
EXPOSE 25545
EXPOSE 25344
EXPOSE 25345
# Create a non-root user
RUN addgroup --system appgroup && adduser --system --ingroup appgroup appuser
USER appuser
VOLUME [ "/app/wireproxy"]
ENTRYPOINT [ "/app/wireproxy/wireproxy" ]
CMD [ "--config", "/app/wireproxy/config" ]
